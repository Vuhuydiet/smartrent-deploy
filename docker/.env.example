# =============================================
# COPY FILE NÀY THÀNH .env VÀ ĐIỀN GIÁ TRỊ
# KHÔNG COMMIT FILE .env LÊN GIT
# =============================================

# Domain (ví dụ: dev.api.smartrent.io.vn)
API_DOMAIN=api.smartrent.io.vn

# Image tags (để latest hoặc điền tag cụ thể)
BACKEND_TAG=latest
AI_TAG=latest
SCRAPER_TAG=latest

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# ---- DATABASE (DO Managed Database) ----
# Lấy từ DigitalOcean → Databases → smartrent-db → Connection Details
DB_HOST=db-smartrent-xxx.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=defaultdb
DB_USERNAME=doadmin
DB_PASSWORD=your_db_password_here

# ---- JWT KEYS (chuỗi random dài, ít nhất 32 ký tự) ----
ACCESS_SIGNER_KEY=your_access_signer_key_here_min_32_chars
REFRESH_SIGNER_KEY=your_refresh_signer_key_here_min_32_chars
RESET_PASSWORD_SIGNER_KEY=your_reset_password_signer_key_here_min_32_chars

# ---- EMAIL (Brevo / SendinBlue) ----
BREVO_API_KEY=your_brevo_api_key
SENDER_EMAIL=smartrent.tools@gmail.com

# ---- GOOGLE OAUTH ----
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_AUTH_CLIENT_REDIRECT_URI=https://smartrent-fe.vercel.app/auth/callback/google

# ---- CLOUDFLARE R2 (S3-compatible storage) ----
S3_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
S3_ACCESS_KEY=your_r2_access_key
S3_SECRET_KEY=your_r2_secret_key
S3_BUCKET=smart-rent
S3_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ---- VNPAY ----
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_RETURN_URL=https://smartrent-fe.vercel.app/payment/result

# ---- GOOGLE MAPS ----
GOOGLE_API_KEY=your_google_maps_api_key

# ---- AI SERVICE ----
GEMINI_API_KEY=your_gemini_api_key

# ---- CLIENT ----
CLIENT_URL=https://smartrent-fe.vercel.app
